{
  "agent": {
    "metrics_collection_interval": 60,
    "run_as_user": "root",
    "region": "ap-south-1"
  },

  "metrics": {
    "namespace": "Jovio/EC2",
    "metrics_collected": {
      "cpu":   { "measurement": ["usage_active", "usage_iowait"], "metrics_collection_interval": 60, "totalcpu": true },
      "mem":   { "measurement": ["mem_used_percent"],             "metrics_collection_interval": 60 },
      "disk":  { "measurement": ["used_percent"],                 "metrics_collection_interval": 60, "resources": ["/"] },
      "swap":  { "measurement": ["swap_used_percent"],            "metrics_collection_interval": 60 },
      "netstat": { "measurement": ["tcp_established", "tcp_time_wait"], "metrics_collection_interval": 60 }
    },
    "append_dimensions": {
      "InstanceId":   "${aws:InstanceId}",
      "InstanceType": "${aws:InstanceType}"
    }
  },

  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path":      "/var/log/jovio-pipeline.out.log",
            "log_group_name": "/jovio/voice-pipeline/stdout",
            "log_stream_name": "{instance_id}",
            "timezone":       "Local",
            "retention_in_days": 30
          },
          {
            "file_path":      "/var/log/jovio-pipeline.err.log",
            "log_group_name": "/jovio/voice-pipeline/stderr",
            "log_stream_name": "{instance_id}",
            "timezone":       "Local",
            "retention_in_days": 30
          },
          {
            "file_path":      "/var/log/jovio-api.out.log",
            "log_group_name": "/jovio/api-server/stdout",
            "log_stream_name": "{instance_id}",
            "timezone":       "Local",
            "retention_in_days": 30
          },
          {
            "file_path":      "/var/log/jovio-api.err.log",
            "log_group_name": "/jovio/api-server/stderr",
            "log_stream_name": "{instance_id}",
            "timezone":       "Local",
            "retention_in_days": 30
          },
          {
            "file_path":      "/var/log/nginx/access.log",
            "log_group_name": "/jovio/nginx/access",
            "log_stream_name": "{instance_id}",
            "timezone":       "Local",
            "retention_in_days": 14
          },
          {
            "file_path":      "/var/log/nginx/error.log",
            "log_group_name": "/jovio/nginx/error",
            "log_stream_name": "{instance_id}",
            "timezone":       "Local",
            "retention_in_days": 30
          }
        ]
      }
    }
  }
}
