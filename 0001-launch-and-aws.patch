diff --git a/infra/aws/setup-cloudwatch.sh b/infra/aws/setup-cloudwatch.sh
new file mode 100755
index 0000000..e48b3c8
--- /dev/null
+++ b/infra/aws/setup-cloudwatch.sh
@@ -0,0 +1,44 @@
+#!/usr/bin/env bash
+# Install + configure CloudWatch Agent on Ubuntu 24 EC2.
+#
+# Prerequisites:
+#   1. Attach an IAM role to this EC2 instance with the AWS-managed policy:
+#        CloudWatchAgentServerPolicy
+#      (EC2 Console → Instance → Actions → Security → Modify IAM role)
+#   2. Run this script with sudo.
+
+set -euo pipefail
+
+REGION="${AWS_REGION:-ap-south-1}"
+REPO_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
+
+echo "▶ Installing CloudWatch Agent (region: $REGION)…"
+
+# Download official CloudWatch Agent .deb for Ubuntu amd64
+cd /tmp
+wget -q "https://s3.${REGION}.amazonaws.com/amazoncloudwatch-agent-${REGION}/ubuntu/amd64/latest/amazon-cloudwatch-agent.deb"
+sudo dpkg -i -E amazon-cloudwatch-agent.deb
+rm -f amazon-cloudwatch-agent.deb
+
+echo "▶ Installing Jovio CloudWatch config…"
+sudo cp "$REPO_ROOT/infra/aws/cloudwatch-agent.json" \
+        /opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json
+
+echo "▶ Starting agent with config…"
+sudo /opt/aws/amazon-cloudwatch-agent/bin/amazon-cloudwatch-agent-ctl \
+    -a fetch-config \
+    -m ec2 \
+    -s \
+    -c file:/opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json
+
+echo "▶ Enabling on boot…"
+sudo systemctl enable amazon-cloudwatch-agent
+
+echo ""
+echo "✓ CloudWatch Agent installed."
+echo ""
+echo "Verify status:"
+echo "   sudo /opt/aws/amazon-cloudwatch-agent/bin/amazon-cloudwatch-agent-ctl -a status"
+echo ""
+echo "Logs will appear in CloudWatch under log groups starting with /jovio/"
+echo "Metrics will appear in CloudWatch → Metrics → Jovio/EC2"
diff --git a/infra/nginx/jovio.conf b/infra/nginx/jovio.conf
new file mode 100644
index 0000000..de11e66
--- /dev/null
+++ b/infra/nginx/jovio.conf
@@ -0,0 +1,55 @@
+# /etc/nginx/sites-available/jovio
+#
+# After copying:
+#   sudo ln -sf /etc/nginx/sites-available/jovio /etc/nginx/sites-enabled/jovio
+#   sudo nginx -t && sudo systemctl reload nginx
+#
+# TLS: get certs with certbot first:
+#   sudo certbot --nginx -d api.jovio.in -d pipeline.jovio.in
+# Certbot auto-edits this file to add the listen 443 ssl blocks.
+
+# ─── API SERVER (api.jovio.in:443 → 127.0.0.1:4000) ───
+server {
+  server_name api.jovio.in;
+  listen 80;
+
+  client_max_body_size 5m;
+
+  # CloudFront / Route 53 health checks hit /health directly
+  location = /health  { proxy_pass http://127.0.0.1:4000/health;  access_log off; }
+  location = /ready   { proxy_pass http://127.0.0.1:4000/ready;   access_log off; }
+
+  location / {
+    proxy_pass         http://127.0.0.1:4000;
+    proxy_http_version 1.1;
+    proxy_set_header   Host              $host;
+    proxy_set_header   X-Real-IP         $remote_addr;
+    proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
+    proxy_set_header   X-Forwarded-Proto $scheme;
+    proxy_set_header   X-Forwarded-Host  $host;
+    proxy_read_timeout 60s;
+  }
+}
+
+# ─── VOICE PIPELINE (pipeline.jovio.in:443 → 127.0.0.1:8000) ───
+server {
+  server_name pipeline.jovio.in;
+  listen 80;
+
+  # Voice pipeline needs WebSocket support for LiveKit signalling
+  location / {
+    proxy_pass         http://127.0.0.1:8000;
+    proxy_http_version 1.1;
+    proxy_set_header   Upgrade           $http_upgrade;
+    proxy_set_header   Connection        "upgrade";
+    proxy_set_header   Host              $host;
+    proxy_set_header   X-Real-IP         $remote_addr;
+    proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
+    proxy_set_header   X-Forwarded-Proto $scheme;
+
+    # Long timeouts — calls can run several minutes
+    proxy_read_timeout    600s;
+    proxy_send_timeout    600s;
+    proxy_connect_timeout 60s;
+  }
+}
diff --git a/infra/systemd/jovio-api.service b/infra/systemd/jovio-api.service
new file mode 100644
index 0000000..f39173a
--- /dev/null
+++ b/infra/systemd/jovio-api.service
@@ -0,0 +1,52 @@
+# Jovio API Server (Node + Express + TypeScript)
+#
+# Install:
+#   sudo cp infra/systemd/jovio-api.service /etc/systemd/system/
+#   sudo systemctl daemon-reload
+#   sudo systemctl enable --now jovio-api
+#
+# NOTE: previous Supervisor config ran `node src/index.ts` which DOES NOT WORK
+# because Node can't run TS directly. The correct ExecStart compiles + runs via
+# ts-node (dev) or pre-built JS (prod). This unit uses ts-node — same behavior
+# as `npm run dev`. For prod, run `npm run build` first then point at dist/.
+
+[Unit]
+Description=Jovio API Server (Express + Razorpay + Wati)
+After=network.target jovio-pipeline.service
+Wants=network-online.target
+
+[Service]
+Type=simple
+User=ubuntu
+Group=ubuntu
+WorkingDirectory=/home/ubuntu/jovi/api-server
+
+# Secrets from: /etc/jovio/api-server.env (mode 0640, owner root:ubuntu)
+# Contains: SUPABASE_*, RAZORPAY_*, WATI_*, INTERNAL_SECRET, PIPELINE_URL,
+# RESEND_*, EXOTEL_WEBHOOK_TOKEN, RAZORPAY_PLAN_*
+EnvironmentFile=/etc/jovio/api-server.env
+
+# Run via ts-node for simplicity. For lower memory: precompile with
+# `npm run build` then change ExecStart to: /usr/bin/node /home/ubuntu/jovi/api-server/dist/index.js
+ExecStart=/home/ubuntu/jovi/api-server/node_modules/.bin/ts-node src/index.ts
+
+Restart=always
+RestartSec=10
+StartLimitBurst=5
+StartLimitIntervalSec=60
+
+StandardOutput=append:/var/log/jovio-api.out.log
+StandardError=append:/var/log/jovio-api.err.log
+
+NoNewPrivileges=true
+PrivateTmp=true
+ProtectSystem=full
+ProtectHome=read-only
+ReadWritePaths=/home/ubuntu/jovi/api-server /var/log
+
+LimitNOFILE=65535
+MemoryHigh=400M
+MemoryMax=512M
+
+[Install]
+WantedBy=multi-user.target
diff --git a/infra/systemd/jovio-pipeline.service b/infra/systemd/jovio-pipeline.service
new file mode 100644
index 0000000..0cb3801
--- /dev/null
+++ b/infra/systemd/jovio-pipeline.service
@@ -0,0 +1,57 @@
+# Jovio Voice Pipeline (Python FastAPI)
+#
+# Install:
+#   sudo cp infra/systemd/jovio-pipeline.service /etc/systemd/system/
+#   sudo systemctl daemon-reload
+#   sudo systemctl enable --now jovio-pipeline
+#
+# Replaces the previous Supervisor config at
+# /etc/supervisor/conf.d/jovio-pipeline.conf — if migrating, first run:
+#   sudo supervisorctl stop jovio-pipeline
+#   sudo rm /etc/supervisor/conf.d/jovio-pipeline.conf
+#   sudo supervisorctl reread && sudo supervisorctl update
+
+[Unit]
+Description=Jovio Voice Pipeline (FastAPI + LiveKit + Sarvam + Gemini)
+After=network.target
+Wants=network-online.target
+
+[Service]
+Type=simple
+User=ubuntu
+Group=ubuntu
+WorkingDirectory=/home/ubuntu/jovi/voice-pipeline
+
+# Load secrets from a file outside the repo. Owner: root:ubuntu, mode 0640.
+# Contains: SUPABASE_URL, SUPABASE_KEY, SARVAM_API_KEY, GEMINI_API_KEY,
+# LIVEKIT_URL/KEY/SECRET, JOVIO_RECORDING_KEY, SUPABASE_RECORDINGS_BUCKET
+EnvironmentFile=/etc/jovio/voice-pipeline.env
+
+ExecStart=/home/ubuntu/jovi/voice-pipeline/venv/bin/uvicorn main:app \
+          --host 0.0.0.0 --port 8000 --workers 2
+
+# Restart policy
+Restart=always
+RestartSec=10
+StartLimitBurst=5
+StartLimitIntervalSec=60
+
+# Logging — journald is captured by the CloudWatch agent via syslog OR
+# we can write to files that the agent tails. Files are simpler.
+StandardOutput=append:/var/log/jovio-pipeline.out.log
+StandardError=append:/var/log/jovio-pipeline.err.log
+
+# Security hardening
+NoNewPrivileges=true
+PrivateTmp=true
+ProtectSystem=full
+ProtectHome=read-only
+ReadWritePaths=/home/ubuntu/jovi/voice-pipeline /var/log
+
+# Resource limits
+LimitNOFILE=65535
+MemoryHigh=1500M
+MemoryMax=1800M
+
+[Install]
+WantedBy=multi-user.target
