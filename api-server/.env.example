# api-server environment variables
# Copy to .env and fill in real values. NEVER commit .env.

# ── Supabase ──
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# ── Razorpay (billing) ──
RAZORPAY_KEY_ID=rzp_live_your_key
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
# Set after running scripts/setup_razorpay_plans.ts:
RAZORPAY_PLAN_STARTER=
RAZORPAY_PLAN_GROWTH=
RAZORPAY_PLAN_SCALE=

# ── WhatsApp (Wati) ──
WATI_API_KEY=your_wati_key
WATI_API_URL=https://live-mt-server.wati.io/YOUR_ACCOUNT

# ── Exotel webhook token (shared secret in URL path) ──
# Generate with: openssl rand -hex 24
# Configure Exotel webhook URL as:
#   https://api.jovio.in/webhooks/exotel/inbound/<this-value>
#   https://api.jovio.in/webhooks/exotel/status/<this-value>
EXOTEL_WEBHOOK_TOKEN=replace-with-openssl-rand-hex-24

# ── Internal service-to-service auth ──
INTERNAL_SECRET=change-this-to-random-string

# ── Voice pipeline ──
PIPELINE_URL=https://pipeline.jovio.in

# ── Email (Resend) ──
RESEND_API_KEY=re_your_resend_key
FROM_EMAIL=noreply@jovio.in

PORT=4000

# ── Sentry (optional, leave blank to disable) ──
# Get from: https://sentry.io → Projects → jovio-api → Client Keys (DSN)
SENTRY_DSN=
NODE_ENV=production
RELEASE_SHA=
