SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key
SARVAM_API_KEY=sk_your_sarvam_key
GEMINI_API_KEY=AQ.your_gemini_key
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
EXOTEL_SID=your_exotel_sid
EXOTEL_API_KEY=your_exotel_api_key
EXOTEL_API_TOKEN=your_exotel_api_token
PLIVO_AUTH_ID=your_plivo_auth_id
PLIVO_AUTH_TOKEN=your_plivo_auth_token
WATI_API_KEY=your_wati_key
WATI_API_URL=https://live-mt-server.wati.io/YOUR_ACCOUNT
INTERNAL_SECRET=change-this-to-random-string
GOOGLE_STT_KEY=your_google_stt_key_fallback
AZURE_SPEECH_KEY=your_azure_key_fallback
AZURE_SPEECH_REGION=centralindia
OPENAI_API_KEY=your_openai_key_fallback

# ─── Call Recording Encryption ───
# AES-256-GCM key, base64-encoded (must decode to exactly 32 bytes).
# Generate one with:
#   python3 -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# For per-tenant keys (stronger), set JOVIO_RECORDING_KEY_<tenant_uuid>=...
JOVIO_RECORDING_KEY=

# Supabase storage bucket for encrypted recordings (must be private)
SUPABASE_RECORDINGS_BUCKET=recordings

# ── Sentry (optional, leave blank to disable) ──
SENTRY_DSN=
JOVIO_ENV=production
RELEASE_SHA=
