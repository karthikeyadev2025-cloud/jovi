From 4a47f20d9cd9c49022509ea37d1f7579235969cd Mon Sep 17 00:00:00 2001
From: Karthikeya <karthi@jovio.in>
Date: Sun, 28 Jun 2026 18:48:50 +0000
Subject: [PATCH 1/3] security(api): require shared-secret token on Exotel
 webhooks
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Exotel doesn't HMAC-sign its webhooks (unlike Razorpay/Stripe). Before
this commit, /webhooks/exotel/inbound and /webhooks/exotel/status were
publicly callable — anyone hitting them could spoof inbound calls and
burn Sarvam + Gemini + LiveKit credits at our expense.

Fix: shared-secret token in URL path.
  /webhooks/exotel/inbound/:token
  /webhooks/exotel/status/:token

The token is verified with crypto.timingSafeEqual against the
EXOTEL_WEBHOOK_TOKEN env var. Missing env fails closed (500) instead
of accepting all requests.

Operator action: generate a token with 'openssl rand -hex 24',
set EXOTEL_WEBHOOK_TOKEN in Railway/EC2 env, and update the Exotel
webhook URLs in the Exotel dashboard to include /<token>.

Also adds /health (liveness, no deps) and /ready (readiness, hits
Supabase). Railway probes these — without them, a half-broken
deploy still receives traffic.

env.example refreshed:
  - new EXOTEL_WEBHOOK_TOKEN entry with how-to-generate comment
  - RAZORPAY_PLAN_STARTER/GROWTH/SCALE slots for setup script output
  - stale k2vob.in / k2vob references swept (jovio.in everywhere)
---
 api-server/.env.example | 30 +++++++++++++++++++--
 api-server/src/index.ts | 60 +++++++++++++++++++++++++++++++++++++++--
 2 files changed, 86 insertions(+), 4 deletions(-)

diff --git a/api-server/.env.example b/api-server/.env.example
index 3e06f78..0618523 100644
--- a/api-server/.env.example
+++ b/api-server/.env.example
@@ -1,12 +1,38 @@
+# api-server environment variables
+# Copy to .env and fill in real values. NEVER commit .env.
+
+# ── Supabase ──
 SUPABASE_URL=https://YOUR_PROJECT.supabase.co
 SUPABASE_SERVICE_KEY=your_service_role_key
+
+# ── Razorpay (billing) ──
 RAZORPAY_KEY_ID=rzp_live_your_key
 RAZORPAY_KEY_SECRET=your_razorpay_secret
 RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
+# Set after running scripts/setup_razorpay_plans.ts:
+RAZORPAY_PLAN_STARTER=
+RAZORPAY_PLAN_GROWTH=
+RAZORPAY_PLAN_SCALE=
+
+# ── WhatsApp (Wati) ──
 WATI_API_KEY=your_wati_key
 WATI_API_URL=https://live-mt-server.wati.io/YOUR_ACCOUNT
+
+# ── Exotel webhook token (shared secret in URL path) ──
+# Generate with: openssl rand -hex 24
+# Configure Exotel webhook URL as:
+#   https://api.jovio.in/webhooks/exotel/inbound/<this-value>
+#   https://api.jovio.in/webhooks/exotel/status/<this-value>
+EXOTEL_WEBHOOK_TOKEN=replace-with-openssl-rand-hex-24
+
+# ── Internal service-to-service auth ──
 INTERNAL_SECRET=change-this-to-random-string
-PIPELINE_URL=https://pipeline.k2vob.in
+
+# ── Voice pipeline ──
+PIPELINE_URL=https://pipeline.jovio.in
+
+# ── Email (Resend) ──
 RESEND_API_KEY=re_your_resend_key
-FROM_EMAIL=noreply@k2vob.in
+FROM_EMAIL=noreply@jovio.in
+
 PORT=4000
diff --git a/api-server/src/index.ts b/api-server/src/index.ts
index 2a519ae..538f263 100644
--- a/api-server/src/index.ts
+++ b/api-server/src/index.ts
@@ -66,7 +66,36 @@ async function getTenantId(userId: string): Promise<string | null> {
 // EXOTEL WEBHOOK — inbound call handler
 // Exotel calls this URL when someone dials your DID
 // ════════════════════════════════════════════════
-app.post("/webhooks/exotel/inbound", async (req, res) => {
+// ── Webhook auth helpers ──
+// Exotel doesn't sign webhooks like Stripe/Razorpay. Protection is a
+// shared-secret token in the URL: caller must hit
+//   /webhooks/exotel/inbound/<EXOTEL_WEBHOOK_TOKEN>
+// Token is configured in Exotel's webhook URL when you set up the DID.
+// Without this, anyone hitting the public endpoint can trigger AI calls
+// (and burn Sarvam/Gemini/LiveKit credits).
+const EXOTEL_TOKEN = process.env.EXOTEL_WEBHOOK_TOKEN || "";
+
+function checkExotelToken(req: any, res: any): boolean {
+  if (!EXOTEL_TOKEN) {
+    // Misconfiguration — fail closed
+    console.error("[Exotel] EXOTEL_WEBHOOK_TOKEN env not set — rejecting");
+    res.status(500).json({ error: "Webhook misconfigured" });
+    return false;
+  }
+  // constant-time compare to prevent timing attacks
+  const provided = req.params.token || "";
+  const ok = provided.length === EXOTEL_TOKEN.length &&
+             crypto.timingSafeEqual(Buffer.from(provided), Buffer.from(EXOTEL_TOKEN));
+  if (!ok) {
+    console.warn(`[Exotel] Bad token from ${req.ip}`);
+    res.status(403).json({ error: "Forbidden" });
+    return false;
+  }
+  return true;
+}
+
+app.post("/webhooks/exotel/inbound/:token", async (req, res) => {
+  if (!checkExotelToken(req, res)) return;
   try {
     // Exotel sends form-encoded data
     const body   = req.body as Record<string, string>;
@@ -121,7 +150,8 @@ app.post("/webhooks/exotel/inbound", async (req, res) => {
 });
 
 // Exotel call status callback
-app.post("/webhooks/exotel/status", async (req, res) => {
+app.post("/webhooks/exotel/status/:token", async (req, res) => {
+  if (!checkExotelToken(req, res)) return;
   try {
     const body = req.body as Record<string, string>;
     const callSid = body.CallSid || "";
@@ -695,6 +725,32 @@ async function sendEmail(tenantId: string, template: string, data: Record<string
   });
 }
 
+// ── HEALTH + READINESS ───────────────────────────────────
+// Railway / k8s probes hit these. Keep them DUMB and FAST.
+//   /health  — process is running (liveness, no deps checked)
+//   /ready   — process can serve traffic (touches DB)
+const STARTED_AT = Date.now();
+
+app.get("/health", (_req, res) => {
+  res.json({
+    status:     "ok",
+    service:    "jovio-api",
+    uptime_ms:  Date.now() - STARTED_AT,
+    pid:        process.pid,
+  });
+});
+
+app.get("/ready", async (_req, res) => {
+  try {
+    // Hit a cheap table to confirm DB reachable. Limit 1 = ~1ms.
+    const { error } = await sb.from("tenants").select("id").limit(1);
+    if (error) throw error;
+    res.json({ status: "ready", db: "ok" });
+  } catch (e: any) {
+    res.status(503).json({ status: "unready", db: "error", message: e.message });
+  }
+});
+
 app.listen(PORT, () => {
   console.log(`Jovio API Server running on port ${PORT}`);
 });
-- 
2.43.0


From 1abb3b0c4eeaf43e6ec2f33682221c628efd09cb Mon Sep 17 00:00:00 2001
